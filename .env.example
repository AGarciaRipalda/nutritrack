# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=nutritrack
POSTGRES_PASSWORD=cambia_esta_contraseña_segura
POSTGRES_DB=nutritrack

# ── Backend ────────────────────────────────────────────────────
# DATABASE_URL se construye automáticamente en docker-compose.yml
# DATA_DIR se establece en docker-compose.yml (/data)

# Credenciales de Google Sheets (opcional, pegar JSON en una línea)
# GOOGLE_CREDENTIALS_JSON=

# ── Frontend ───────────────────────────────────────────────────
# En producción cambia a http://<IP-PUBLICA>:8000 o tu dominio
NEXT_PUBLIC_API_URL=http://localhost:8000
